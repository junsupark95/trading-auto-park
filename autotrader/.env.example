# ============================================================
# Korean Aggressive Opening Momentum - 환경변수 설정
# ============================================================
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# ---- 운용 모드 ----
# paper: 모의투자, live: 실전투자
TRADING_MODE=paper
# 실전 주문 활성화 플래그 (live 모드에서만 의미 있음)
LIVE_TRADING=false
# 실전 주문 이중 확인 플래그
CONFIRM_LIVE_ORDERS=false

# ---- 한국투자증권 Open API ----
# 실전투자
KIS_APP_KEY=your_real_app_key
KIS_APP_SECRET=your_real_app_secret
KIS_ACCOUNT_NO=your_account_8digit
KIS_ACCOUNT_PROD=01
KIS_HTS_ID=your_hts_id
# 모의투자
KIS_PAPER_APP_KEY=your_paper_app_key
KIS_PAPER_APP_SECRET=your_paper_app_secret
KIS_PAPER_ACCOUNT_NO=your_paper_account_8digit

# ---- 데이터베이스 (PostgreSQL) ----
# Supabase Free 예시: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# DB 연결 실패 시 시스템 HALTED 전환
DB_FAIL_HALTS_SYSTEM=true

# ---- AI (Gemini 2.5 Flash Lite) ----
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
AI_ENABLED=true
AI_DAILY_CALL_LIMIT=500
AI_COOLDOWN_SECONDS=30

# ---- 전략 파라미터 (기본값 사용 시 생략 가능) ----
# GAP_UP_MIN_PCT=3.0
# GAP_UP_MAX_PCT=15.0
# ORB_PERIOD_MINUTES=5
# INITIAL_STOP_LOSS_PCT=1.5
# MAX_POSITIONS=2
# MAX_DAILY_ENTRIES=6
# POSITION_SIZE_PCT=20.0

# ---- 리스크 한도 ----
DAILY_LOSS_LIMIT_PCT=3.0
PER_SYMBOL_LOSS_LIMIT_PCT=1.5
MAX_API_ERROR_COUNT=5
UNFILLED_TIMEOUT_SECONDS=60
# 시작 자본금 (원, 손실 한도 계산 기준)
STARTING_CAPITAL=10000000

# ---- 서버 ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
